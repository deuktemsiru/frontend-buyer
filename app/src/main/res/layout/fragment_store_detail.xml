<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero image -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/hero_image_height">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#FFD4B5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🥐"
                    android:textSize="64sp" />

                <!-- Back button -->
                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="@dimen/touch_target_min"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_gravity="top|start"
                    android:layout_margin="8dp"
                    android:src="@drawable/ic_back"
                    android:background="@color/white"
                    android:elevation="4dp"
                    android:contentDescription="뒤로가기" />

                <!-- Share + Wishlist -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btn_share"
                        android:layout_width="@dimen/touch_target_min"
                        android:layout_height="@dimen/touch_target_min"
                        android:src="@drawable/ic_share"
                        android:background="@color/white"
                        android:elevation="4dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="공유" />

                    <ImageButton
                        android:id="@+id/btn_wishlist"
                        android:layout_width="@dimen/touch_target_min"
                        android:layout_height="@dimen/touch_target_min"
                        android:src="@drawable/ic_heart"
                        android:background="@color/white"
                        android:elevation="4dp"
                        android:contentDescription="찜" />
                </LinearLayout>
            </FrameLayout>

            <!-- Store info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_store_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="파리바게뜨 정왕점"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_text" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="단골"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary_dark"
                        android:background="@drawable/bg_grade_badge" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star"
                        android:contentDescription="별점" />

                    <TextView
                        android:id="@+id/tv_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="4.8"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/color_text_sub" />

                    <View
                        android:layout_width="3dp"
                        android:layout_height="3dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@color/color_text_muted" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_location"
                        android:contentDescription="거리" />

                    <TextView
                        android:id="@+id/tv_walk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="도보 4분"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/color_text_sub" />
                </LinearLayout>
            </LinearLayout>

            <!-- Countdown timer card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_timer_card"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="4dp">

                <!-- Left circle -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_timer_circle">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="마감"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tv_timer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="42:00"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Right info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="픽업 가능 시간"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/primary_dark" />

                    <TextView
                        android:id="@+id/tv_pickup_range"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="17:00 - 18:30"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="가게에서 직접 픽업해 가세요"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/primary_dark" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="16dp"
                android:background="@color/color_surface" />

            <!-- Menu section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오늘만이 픽업 메뉴"
                    android:textSize="@dimen/text_title"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_text"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_menus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="@dimen/spacing_lg"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/btn_wishlist_bottom"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_heart"
            android:background="@drawable/bg_store_card"
            android:contentDescription="찜" />

        <Button
            android:id="@+id/btn_reserve"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="5,900원 예약하기"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/white"
            android:background="@drawable/bg_primary_button"
            android:stateListAnimator="@null" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
