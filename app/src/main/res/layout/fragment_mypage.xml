<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Profile header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/white"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="24dp"
            android:paddingBottom="20dp">

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_timer_circle">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🌱"
                    android:textSize="26sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_nickname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="정음식"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_text" />

                    <TextView
                        android:id="@+id/tv_grade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:text="🌱 새싹"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary_dark"
                        android:background="@drawable/bg_grade_badge" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="음식 구조대원"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/color_text_sub" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="8dp" android:background="@color/color_surface" />

        <!-- Savings card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_savings_card"
            android:padding="20dp"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="총 절약 금액"
                        android:textSize="12sp"
                        android:textColor="#FFCFB8" />

                    <TextView
                        android:id="@+id/tv_total_savings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="87,400원"
                        android:textSize="@dimen/text_display"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="구한 음식"
                        android:textSize="12sp"
                        android:textColor="#FFCFB8" />

                    <TextView
                        android:id="@+id/tv_saved_food"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="23개"
                        android:textSize="@dimen/text_headline"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/white" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Sub stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_card"
                android:padding="@dimen/spacing_lg"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="이번 달 절약"
                    android:textSize="12sp"
                    android:textColor="@color/color_text_sub" />

                <TextView
                    android:id="@+id/tv_month_savings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="12,300원"
                    android:textSize="@dimen/text_title"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_text" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_card"
                android:padding="@dimen/spacing_lg"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="탄소 절감"
                    android:textSize="12sp"
                    android:textColor="@color/color_text_sub" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌱"
                        android:textSize="14sp"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tv_carbon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.6kg"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/success" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Grade progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="다음 등급까지"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_text" />

                <TextView
                    android:id="@+id/tv_next_grade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7개 더 구하면 🌳"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/color_text_sub" />
            </LinearLayout>

            <!-- Progress bar -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/bg_progress_track">

                <View
                    android:id="@+id/progress_grade"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_primary_button" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="23/30"
                    android:textSize="12sp"
                    android:textColor="@color/color_text_sub" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="76%"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Quick stats 3-way -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/white"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎟️"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tv_coupon_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="2"
                    android:textSize="@dimen/text_title"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="쿠폰함"
                    android:textSize="12sp"
                    android:textColor="@color/color_text_sub" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/color_border" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💎"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tv_points"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="1,200P"
                    android:textSize="@dimen/text_title"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="포인트"
                    android:textSize="12sp"
                    android:textColor="@color/color_text_sub" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/color_border" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤍"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tv_wishlist_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="5"
                    android:textSize="@dimen/text_title"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="찜"
                    android:textSize="12sp"
                    android:textColor="@color/color_text_sub" />
            </LinearLayout>
        </LinearLayout>

        <!-- Menu list -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white">

            <LinearLayout
                android:id="@+id/menu_orders"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="주문 내역"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="이동" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_border" android:layout_marginHorizontal="@dimen/spacing_lg" />

            <LinearLayout
                android:id="@+id/menu_places"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="자주 가는 위치"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="이동" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_border" android:layout_marginHorizontal="@dimen/spacing_lg" />

            <LinearLayout
                android:id="@+id/menu_notifications"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="알림 설정"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="이동" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_border" android:layout_marginHorizontal="@dimen/spacing_lg" />

            <LinearLayout
                android:id="@+id/menu_support"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="고객 문의"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="이동" />
            </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="24dp" />
    </LinearLayout>
</ScrollView>
