<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_surface">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:paddingStart="4dp"
            android:paddingEnd="@dimen/spacing_lg">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="뒤로가기" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="찜"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:paddingBottom="8dp"
                android:paddingTop="8dp" />

        </LinearLayout>

        <!-- 카테고리 칩 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chip_all"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="전체"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_chip_selected"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chip_bakery"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="베이커리"
                    android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chip_lunchbox"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="도시락"
                    android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chip_salad"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="샐러드"
                    android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chip_cafe"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="카페"
                    android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected" />

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- 컨텐츠 영역 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 목록 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_wishlist"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/spacing_lg"
            android:clipToPadding="false"
            android:visibility="gone" />

        <!-- 빈 상태 -->
        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="찜"
                android:textSize="96sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/color_text"
                android:letterSpacing="-0.05"
                android:layout_marginBottom="8dp" />

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_heart_filled"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="자주 찾는 가게를 찜 해보세요"
                android:textSize="15sp"
                android:textColor="@color/color_text_sub" />

        </LinearLayout>

        <!-- 로딩 -->
        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="visible" />

    </FrameLayout>

</LinearLayout>