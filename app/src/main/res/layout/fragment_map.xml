<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_sheet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header -->
    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_target_min"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                android:contentDescription="위치" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="시흥시 정왕동"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:layout_marginStart="4dp" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_arrow_right"
                android:rotation="90"
                android:layout_marginStart="4dp"
                android:contentDescription="위치 변경" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="시흥시 BI"
                android:scaleType="fitCenter"
                android:src="@drawable/img_siheung_bi" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_search"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_bar"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:contentDescription="검색"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_map_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="@string/home_search_hint"
                android:textSize="@dimen/text_body"
                android:textColor="@color/color_text"
                android:textColorHint="@color/color_text_muted"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1" />

            <ImageButton
                android:id="@+id/btn_map_search"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_search"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="검색" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/hsv_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="10dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chip_all"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="@string/cat_all"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_chip_selected"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chip_korean"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="@string/cat_korean"
                    android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chip_western"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="@string/cat_western"
                    android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chip_cafe_dessert"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="@string/cat_cafe_dessert"
                    android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chip_bakery"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="@string/cat_bakery"
                    android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chip_cafe"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="@string/cat_cafe"
                    android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Zoom in button -->
    <FrameLayout
        android:id="@+id/btn_zoom_in"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:layout_marginBottom="4dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_zoom_out">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="+"
            android:textSize="22sp"
            android:textColor="@color/color_text"
            android:fontFamily="sans-serif-medium" />
    </FrameLayout>

    <!-- Zoom out button -->
    <FrameLayout
        android:id="@+id/btn_zoom_out"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:layout_marginBottom="4dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_my_location">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="−"
            android:textSize="22sp"
            android:textColor="@color/color_text"
            android:fontFamily="sans-serif-medium" />
    </FrameLayout>

    <!-- Current location button -->
    <FrameLayout
        android:id="@+id/btn_my_location"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:background="@color/white"
        android:elevation="4dp"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_sheet">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_location"
            android:contentDescription="현재 위치" />
    </FrameLayout>

    <!-- Bottom sheet with store list -->
    <LinearLayout
        android:id="@+id/ll_bottom_sheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_progress_track" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginBottom="8dp"
            android:text="주변 마감 임박 가게"
            android:textSize="@dimen/text_body"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/color_text" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingBottom="16dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/ll_map_stores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
