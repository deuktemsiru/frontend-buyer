<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <!-- Map placeholder (실제 구현 시 Naver Map Fragment로 교체) -->
    <FrameLayout
        android:id="@+id/fl_map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#D4E8C2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_sheet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Grid lines to mimic map -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="4"
            android:rowCount="6"
            android:alpha="0.3">
        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🗺️"
            android:textSize="48sp"
            android:alpha="0.4" />

        <!-- Mock map pins -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="40dp"
            android:layout_marginTop="-40dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:background="@drawable/bg_discount_badge">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60% 5,900원"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/white" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginEnd="50dp"
            android:layout_marginTop="60dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50% 8,500원"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_chip_selected"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Current location dot -->
        <FrameLayout
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.2"
                android:background="@drawable/bg_timer_circle" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_timer_circle" />
        </FrameLayout>
    </FrameLayout>

    <!-- Category chips -->
    <HorizontalScrollView
        android:id="@+id/hsv_categories"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="전체"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/white"
                android:background="@drawable/bg_chip_selected"
                android:layout_marginEnd="8dp"
                android:elevation="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="베이커리"
                android:textSize="13sp"
                android:textColor="@color/color_text"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="8dp"
                android:elevation="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="도시락"
                android:textSize="13sp"
                android:textColor="@color/color_text"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="8dp"
                android:elevation="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="샐러드"
                android:textSize="13sp"
                android:textColor="@color/color_text"
                android:background="@drawable/bg_chip_unselected"
                android:elevation="2dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Current location button -->
    <FrameLayout
        android:id="@+id/btn_my_location"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="@dimen/spacing_lg"
        android:background="@color/white"
        android:elevation="4dp"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_sheet">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_location"
            android:contentDescription="현재 위치" />
    </FrameLayout>

    <!-- Bottom sheet with store list -->
    <LinearLayout
        android:id="@+id/ll_bottom_sheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_progress_track" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginBottom="8dp"
            android:text="주변 마감 임박 가게"
            android:textSize="@dimen/text_body"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/color_text" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingBottom="16dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/ll_map_stores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
