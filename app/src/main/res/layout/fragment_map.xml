<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_sheet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Category chips -->
    <HorizontalScrollView
        android:id="@+id/hsv_categories"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="전체"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/white"
                android:background="@drawable/bg_chip_selected"
                android:layout_marginEnd="8dp"
                android:elevation="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="베이커리"
                android:textSize="13sp"
                android:textColor="@color/color_text"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="8dp"
                android:elevation="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="음식점"
                android:textSize="13sp"
                android:textColor="@color/color_text"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="8dp"
                android:elevation="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="카페"
                android:textSize="13sp"
                android:textColor="@color/color_text"
                android:background="@drawable/bg_chip_unselected"
                android:elevation="2dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Zoom in button -->
    <FrameLayout
        android:id="@+id/btn_zoom_in"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:layout_marginBottom="4dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_zoom_out">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="+"
            android:textSize="22sp"
            android:textColor="@color/color_text"
            android:fontFamily="sans-serif-medium" />
    </FrameLayout>

    <!-- Zoom out button -->
    <FrameLayout
        android:id="@+id/btn_zoom_out"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:layout_marginBottom="4dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_my_location">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="−"
            android:textSize="22sp"
            android:textColor="@color/color_text"
            android:fontFamily="sans-serif-medium" />
    </FrameLayout>

    <!-- Current location button -->
    <FrameLayout
        android:id="@+id/btn_my_location"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:background="@color/white"
        android:elevation="4dp"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_sheet">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_location"
            android:contentDescription="현재 위치" />
    </FrameLayout>

    <!-- Bottom sheet with store list -->
    <LinearLayout
        android:id="@+id/ll_bottom_sheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_progress_track" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginBottom="8dp"
            android:text="주변 마감 임박 가게"
            android:textSize="@dimen/text_body"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/color_text" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingBottom="16dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/ll_map_stores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
