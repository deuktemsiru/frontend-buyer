<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:paddingHorizontal="@dimen/spacing_lg">

    <LinearLayout
        android:id="@+id/ll_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="76dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="시루 연동"
            android:textColor="@color/color_text"
            android:textSize="@dimen/text_display" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="지역화폐 시루로 결제할 수 있도록 연동을 준비합니다."
            android:textColor="@color/color_text_sub"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_siru_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:background="@drawable/bg_siru_payment"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="시흥시 BI"
                android:scaleType="fitCenter"
                android:src="@drawable/img_siheung_bi" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="SIHEUNG SIRU"
                android:textColor="@color/siru_green"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:fontFamily="sans-serif-medium"
            android:text="시흥화폐 시루"
            android:textColor="@color/color_text"
            android:textSize="@dimen/text_headline" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="테스트 계정 010-0000-1234"
            android:textColor="@color/color_text_sub"
            android:textSize="@dimen/text_body" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif-medium"
            android:text="잔액 24,500원"
            android:textColor="@color/siru_green"
            android:textSize="@dimen/text_title" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_link_siru"
        android:layout_width="0dp"
        android:layout_height="@dimen/cta_button_height"
        android:layout_marginBottom="74dp"
        android:background="@drawable/bg_primary_button"
        android:backgroundTint="@null"
        android:fontFamily="sans-serif-medium"
        android:stateListAnimator="@null"
        android:text="시루 연동 완료하고 시작하기"
        android:textColor="@color/white"
        android:textSize="@dimen/text_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_skip"
        android:layout_width="0dp"
        android:layout_height="@dimen/cta_button_height"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_surface_card"
        android:backgroundTint="@null"
        android:fontFamily="sans-serif-medium"
        android:stateListAnimator="@null"
        android:text="나중에 하기"
        android:textColor="@color/color_text_sub"
        android:textSize="@dimen/text_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
