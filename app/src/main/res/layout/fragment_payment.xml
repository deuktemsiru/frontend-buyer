<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/ll_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:paddingHorizontal="@dimen/spacing_sm"
        android:paddingVertical="@dimen/spacing_xs">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로가기" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/payment_title"
            android:textSize="@dimen/text_title"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/color_text"
            android:gravity="center" />

        <View android:layout_width="@dimen/touch_target_min" android:layout_height="@dimen/touch_target_min" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/toolbar_height"
        android:layout_marginBottom="@dimen/bottom_cta_offset">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Order summary -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/white"
                android:padding="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_md">

                <FrameLayout
                    android:layout_width="@dimen/payment_thumbnail_size"
                    android:layout_height="@dimen/payment_thumbnail_size">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_thumbnail_placeholder" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🥐"
                        android:textSize="@dimen/emoji_lg" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tv_store_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="파리바게뜨 정왕점"
                        android:textSize="@dimen/text_body"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_text" />

                    <TextView
                        android:id="@+id/tv_menu_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="아침 세트 A 외 1개"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/color_text_sub" />
                </LinearLayout>
            </LinearLayout>

            <!-- Pickup time selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_pickup_time_select"
                android:textSize="@dimen/text_title"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/grid_time_slots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:columnCount="2"
                app:rowCount="2">

                <Button
                    android:id="@+id/slot_1"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/payment_slot_height"
                    app:layout_columnWeight="1"
                    android:layout_margin="@dimen/spacing_xs"
                    android:text="17:00"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_time_slot_selected"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/slot_2"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/payment_slot_height"
                    app:layout_columnWeight="1"
                    android:layout_margin="@dimen/spacing_xs"
                    android:text="17:30"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_time_slot"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/slot_3"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/payment_slot_height"
                    app:layout_columnWeight="1"
                    android:layout_margin="@dimen/spacing_xs"
                    android:text="18:00"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_time_slot"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/payment_slot_height"
                    app:layout_columnWeight="1"
                    android:layout_margin="@dimen/spacing_xs"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_time_slot">

                    <Button
                        android:id="@+id/slot_4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/payment_deadline_slot_1830"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/danger"
                        android:background="@android:color/transparent"
                        app:backgroundTint="@null"
                        android:stateListAnimator="@null" />
                </LinearLayout>

            </androidx.gridlayout.widget.GridLayout>

            <!-- Payment method -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_payment_method"
                android:textSize="@dimen/text_title"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <LinearLayout
                android:id="@+id/ll_siru_payment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_siru_payment"
                android:padding="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_md">

                <RadioButton
                    android:id="@+id/rb_siru"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="@string/payment_method_siru"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/siru_green"
                    android:buttonTint="@color/siru_green"
                    android:clickable="false"
                    android:checked="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/touch_target_min"
                    android:text="@string/payment_method_siru_balance"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/color_text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/touch_target_min"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/payment_method_siru_notice"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/color_text_sub" />
            </LinearLayout>

            <!-- Coupon row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/white"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_md">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_coupon"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_coupon_available_none"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/primary" />

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:src="@drawable/ic_arrow_right"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:contentDescription="쿠폰 선택" />
            </LinearLayout>

            <!-- Price breakdown -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_md">

                <LinearLayout android:layout_width="match_parent" android:layout_height="@dimen/touch_target_min" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/label_order_price" android:textSize="@dimen/text_body" android:textColor="@color/color_text_sub" />
                    <TextView android:id="@+id/tv_order_price" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15,000원" android:textSize="@dimen/text_body" android:textColor="@color/color_text" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="@dimen/touch_target_min" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/label_closing_discount" android:textSize="@dimen/text_body" android:textColor="@color/color_text_sub" />
                    <TextView android:id="@+id/tv_discount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-9,000원" android:textSize="@dimen/text_body" android:textColor="@color/danger" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="@dimen/touch_target_min" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/label_first_order_discount" android:textSize="@dimen/text_body" android:textColor="@color/color_text_sub" />
                    <TextView android:id="@+id/tv_extra_discount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-1,000원" android:textSize="@dimen/text_body" android:textColor="@color/danger" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="@dimen/payment_divider_height" android:background="@color/color_border" android:layout_marginVertical="@dimen/spacing_sm" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="@dimen/touch_target_min" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/label_final_price" android:textSize="@dimen/text_title" android:fontFamily="sans-serif-medium" android:textColor="@color/color_text" />
                    <TextView android:id="@+id/tv_final_price" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5,000원" android:textSize="@dimen/text_title" android:fontFamily="sans-serif-medium" android:textColor="@color/primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Savings message -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_success_message"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌱"
                    android:textSize="@dimen/emoji_md"
                    android:layout_marginEnd="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tv_savings_message"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="10,100원을 절약하고 음식 1개를 구해요"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/success" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom CTA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:padding="@dimen/spacing_lg">

        <Button
            android:id="@+id/btn_pay"
            android:layout_width="match_parent"
            android:layout_height="@dimen/cta_button_height"
            android:text="@string/btn_pay_placeholder"
            android:textSize="@dimen/text_button"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/white"
            android:background="@drawable/bg_primary_button"
            android:stateListAnimator="@null" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
