<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:paddingHorizontal="@dimen/spacing_lg">

    <!-- Title area -->
    <LinearLayout
        android:id="@+id/ll_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="72dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="반가워요!"
            android:textSize="@dimen/text_headline"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/color_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="아래 약관에 동의하면"
            android:textSize="@dimen/text_headline"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/color_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="아까운 음식 구하기 시작!"
            android:textSize="@dimen/text_headline"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/primary" />
    </LinearLayout>

    <!-- Illustration placeholder -->
    <FrameLayout
        android:id="@+id/fl_illustration"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/ll_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🦕"
            android:textSize="80sp" />
    </FrameLayout>

    <!-- Terms section -->
    <LinearLayout
        android:id="@+id/ll_terms"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_surface_card"
        android:padding="@dimen/spacing_lg"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/fl_illustration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Agree all row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_target_min"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/cb_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/primary"
                android:text="전체 동의"
                android:textSize="@dimen/text_body"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@color/color_border" />

        <!-- Required -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_target_min"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/cb_terms"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/primary"
                android:text="이용약관 동의 (필수)"
                android:textSize="@dimen/text_body"
                android:textColor="@color/color_text_sub" />

            <TextView
                android:id="@+id/tv_terms_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전문보기"
                android:textSize="12sp"
                android:textColor="@color/color_text_muted"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Optional -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_target_min"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/cb_privacy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/primary"
                android:text="개인정보 수집·이용 동의 (선택)"
                android:textSize="@dimen/text_body"
                android:textColor="@color/color_text_sub" />

            <TextView
                android:id="@+id/tv_privacy_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전문보기"
                android:textSize="12sp"
                android:textColor="@color/color_text_muted"
                android:padding="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom CTA -->
    <Button
        android:id="@+id/btn_start"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginBottom="16dp"
        android:text="시작하기"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/white"
        android:background="@drawable/bg_dark_button"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
