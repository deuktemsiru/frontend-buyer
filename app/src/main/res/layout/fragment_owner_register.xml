<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/ll_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로가기" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="마감 메뉴 등록"
            android:textSize="@dimen/text_title"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/color_text"
            android:gravity="center" />

        <View android:layout_width="@dimen/touch_target_min" android:layout_height="@dimen/touch_target_min" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Guide card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_owner_guide"
                android:padding="@dimen/spacing_lg"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️"
                    android:textSize="24sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3분이면 끝나요.\n사진 찍고, 가격 정하고, 등록"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/primary_dark"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>

            <!-- Step 1: Photo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1단계  메뉴 사진"
                android:textSize="@dimen/text_title"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:id="@+id/fl_photo_main"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_photo_slot"
                    android:layout_marginEnd="12dp"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_camera"
                            android:contentDescription="사진 추가" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="대표 사진"
                            android:textSize="11sp"
                            android:textColor="@color/color_text_muted" />
                    </LinearLayout>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/fl_photo_extra"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_photo_slot"
                    android:layout_gravity="center_vertical"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_plus"
                        android:contentDescription="추가 사진" />
                </FrameLayout>
            </LinearLayout>

            <!-- Step 2: Menu name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2단계  메뉴 이름"
                android:textSize="@dimen/text_title"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/et_menu_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="메뉴 이름을 입력해 주세요"
                android:textSize="@dimen/text_body"
                android:textColor="@color/color_text"
                android:textColorHint="@color/color_text_muted"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:inputType="text"
                android:maxLines="1"
                android:layout_marginBottom="20dp" />

            <!-- Step 3: Price -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3단계  가격 설정"
                android:textSize="@dimen/text_title"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="@dimen/spacing_lg"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="정상가"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/color_text_sub" />

                    <EditText
                        android:id="@+id/et_original_price"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:hint="0"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/color_text"
                        android:textColorHint="@color/color_text_muted"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:inputType="number"
                        android:maxLines="1"
                        android:gravity="end" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="원"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/color_text_sub" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_border" android:layout_marginVertical="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="마감 할인가"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/color_text_sub" />

                    <EditText
                        android:id="@+id/et_discount_price"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:hint="0"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/primary"
                        android:textColorHint="@color/color_text_muted"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:inputType="number"
                        android:maxLines="1"
                        android:gravity="end" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="원"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/color_text_sub" />
                </LinearLayout>
            </LinearLayout>

            <!-- Discount presets -->
            <LinearLayout
                android:id="@+id/ll_presets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <Button android:id="@+id/preset_30"
                    android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:layout_marginEnd="6dp"
                    android:text="30%" android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:stateListAnimator="@null" />

                <Button android:id="@+id/preset_50"
                    android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:layout_marginEnd="6dp"
                    android:text="50%" android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:stateListAnimator="@null" />

                <Button android:id="@+id/preset_60"
                    android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:layout_marginEnd="6dp"
                    android:text="60%" android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:stateListAnimator="@null" />

                <Button android:id="@+id/preset_70"
                    android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="70%" android:textSize="13sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_chip_unselected"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- Step 4: Stock + time -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4단계  수량 · 시간"
                android:textSize="@dimen/text_title"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:layout_marginBottom="10dp" />

            <!-- Stock stepper -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/white"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="수량"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/btn_minus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="−"
                        android:textSize="18sp"
                        android:textColor="@color/color_text"
                        android:background="@drawable/bg_stepper_button"
                        android:stateListAnimator="@null"
                        android:padding="0dp" />

                    <TextView
                        android:id="@+id/tv_stock_count"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_text"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/btn_plus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="+"
                        android:textSize="18sp"
                        android:textColor="@color/color_text"
                        android:background="@drawable/bg_stepper_button"
                        android:stateListAnimator="@null"
                        android:padding="0dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Time pickers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/white"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingVertical="12dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="픽업 시작"
                        android:textSize="12sp"
                        android:textColor="@color/color_text_sub"
                        android:layout_marginBottom="6dp" />

                    <Button
                        android:id="@+id/btn_pickup_start"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="17:00"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/color_text"
                        android:background="@drawable/bg_input"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="마감 시간"
                        android:textSize="12sp"
                        android:textColor="@color/color_text_sub"
                        android:layout_marginBottom="6dp" />

                    <Button
                        android:id="@+id/btn_pickup_end"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="18:30"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/color_text"
                        android:background="@drawable/bg_input"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- Notify toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/white"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tv_notify_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="찜한 손님 38명에게 발송"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_notify"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:trackTint="@color/primary" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="@dimen/spacing_lg"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <Button
            android:id="@+id/btn_preview"
            android:layout_width="100dp"
            android:layout_height="52dp"
            android:layout_marginEnd="10dp"
            android:text="미리보기"
            android:textSize="14sp"
            android:textColor="@color/color_text"
            android:background="@drawable/bg_store_card"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn_register"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="등록하고 알림 보내기"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/white"
            android:background="@drawable/bg_primary_button"
            android:stateListAnimator="@null" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
