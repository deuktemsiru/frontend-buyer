<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top gradient line (receipt style) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@drawable/bg_savings_card" />

        <!-- Header section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:gravity="center_horizontal">

            <!-- Status badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="픽업 대기 중"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/primary"
                android:background="@drawable/bg_pickup_badge"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_pickup_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5시 30분까지"
                android:textSize="@dimen/text_headline"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="가게에서 받아 가세요!"
                android:textSize="@dimen/text_headline"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:gravity="center" />

            <!-- Pickup code -->
            <LinearLayout
                android:id="@+id/ll_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_code_box"
                android:padding="20dp"
                android:gravity="center"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="픽업 코드"
                    android:textSize="12sp"
                    android:textColor="@color/primary_dark"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_pickup_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A 4 2 K"
                    android:textSize="32sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.3"
                    android:textColor="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="길게 눌러 복사"
                    android:textSize="11sp"
                    android:textColor="@color/color_text_muted" />
            </LinearLayout>

            <!-- Countdown -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_clock"
                    android:contentDescription="남은 시간"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tv_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="42:00"
                    android:textSize="28sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/danger" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="@color/color_surface" />

        <!-- Store info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tv_store_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="파리바게뜨 정왕점"
                android:textSize="@dimen/text_title"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_store_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="경기도 시흥시 정왕동 1234-56"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/color_text_sub"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btn_directions"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="길찾기"
                    android:textSize="14sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_surface_card"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btn_call"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="전화하기"
                    android:textSize="14sp"
                    android:textColor="@color/color_text"
                    android:background="@drawable/bg_surface_card"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="@color/color_surface" />

        <!-- Order summary -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="주문 메뉴"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text_sub" />

                <TextView
                    android:id="@+id/tv_order_menu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="아침 세트 A"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="결제 금액"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text_sub" />

                <TextView
                    android:id="@+id/tv_paid_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5,000원"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_border"
                android:layout_marginVertical="8dp" />

            <!-- Success message -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_success_message"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💝"
                    android:textSize="18sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="아까운 음식을 구해주셨어요. 고마워요!"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/success" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="24dp" />
    </LinearLayout>
</ScrollView>
