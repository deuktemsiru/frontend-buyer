<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary_light"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- Top row: location + icons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_target_min"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                android:contentDescription="위치" />

            <TextView
                android:id="@+id/tv_location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="정왕동"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text"
                android:layout_marginStart="4dp" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="시흥시 BI"
                android:scaleType="fitCenter"
                android:src="@drawable/img_siheung_bi" />

            <ImageButton
                android:id="@+id/btn_bell"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:src="@drawable/ic_bell"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="알림" />

            <FrameLayout
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min">

                <ImageButton
                    android:id="@+id/btn_cart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_cart"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="장바구니" />

                <TextView
                    android:id="@+id/tv_cart_badge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_cart_badge"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone" />

            </FrameLayout>
        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:id="@+id/ll_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/white"
            android:elevation="4dp"
            android:padding="4dp">

            <EditText
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="@string/map_search_hint"
                android:textSize="@dimen/text_body"
                android:textColor="@color/color_text"
                android:textColorHint="@color/color_text_muted"
                android:background="@android:color/transparent"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1" />

            <ImageButton
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_camera"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="필터" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="140dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Category chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingVertical="12dp"
                android:background="@color/white">

                <LinearLayout
                    android:id="@+id/ll_categories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/chip_all"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="전체"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_chip_selected"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/chip_bakery"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="베이커리"
                        android:textSize="13sp"
                        android:textColor="@color/color_text"
                        android:background="@drawable/bg_chip_unselected"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/chip_lunchbox"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="음식점"
                        android:textSize="13sp"
                        android:textColor="@color/color_text"
                        android:background="@drawable/bg_chip_unselected"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/chip_salad"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone"
                        android:textSize="13sp"
                        android:textColor="@color/color_text"
                        android:background="@drawable/bg_chip_unselected"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/chip_cafe"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="카페"
                        android:textSize="13sp"
                        android:textColor="@color/color_text"
                        android:background="@drawable/bg_chip_unselected" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Store list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_stores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/ll_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="48dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:contentDescription="시흥시 캐릭터"
                    android:scaleType="fitCenter"
                    android:src="@drawable/img_siheung_character" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="조금 더 기다려볼까요?"
                    android:textSize="@dimen/text_title"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_text"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="주변에 마감 임박 가게가 없어요.\n알림 신청 시 바로 알려드릴게요!"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/color_text_sub"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
