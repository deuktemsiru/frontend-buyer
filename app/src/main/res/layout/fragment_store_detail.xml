<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero image -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/hero_image_height">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/primary_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🥐"
                    android:textSize="64sp" />

                <!-- Back button -->
                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="@dimen/touch_target_min"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_gravity="top|start"
                    android:layout_margin="8dp"
                    android:src="@drawable/ic_back"
                    android:background="@color/white"
                    android:elevation="4dp"
                    android:contentDescription="뒤로가기" />

                <!-- Share + Wishlist -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btn_share"
                        android:layout_width="@dimen/touch_target_min"
                        android:layout_height="@dimen/touch_target_min"
                        android:src="@drawable/ic_share"
                        android:background="@color/white"
                        android:elevation="4dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="공유" />

                    <ImageButton
                        android:id="@+id/btn_wishlist"
                        android:layout_width="@dimen/touch_target_min"
                        android:layout_height="@dimen/touch_target_min"
                        android:src="@drawable/ic_heart"
                        android:background="@color/white"
                        android:elevation="4dp"
                        android:contentDescription="찜" />
                </LinearLayout>
            </FrameLayout>

            <!-- Store info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_lg"
                android:paddingBottom="@dimen/spacing_md">

                <!-- Name + grade badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_store_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="정왕동 꿀맛 베이커리"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_text" />

                    <TextView
                        android:id="@+id/tv_grade_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="@string/label_regular"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary_dark"
                        android:background="@drawable/bg_grade_badge" />
                </LinearLayout>

                <!-- Rating + distance -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star"
                        android:contentDescription="별점" />

                    <TextView
                        android:id="@+id/tv_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="4.8"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/color_text_sub" />

                    <View
                        android:layout_width="3dp"
                        android:layout_height="3dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@color/color_text_muted" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_location"
                        android:contentDescription="거리" />

                    <TextView
                        android:id="@+id/tv_walk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="300m · 도보 4분"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/color_text_sub" />
                </LinearLayout>

                <!-- Store message -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_siru_payment"
                    android:padding="12dp"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥐"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_store_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="아까운 음식을 구매해주셔서 감사해요😊"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/siru_green" />
                </LinearLayout>

                <!-- Address -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location"
                        android:contentDescription="주소"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_address"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="경기 시흥시 중앙상가로 123 1층"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/color_text_sub" />

                    <TextView
                        android:id="@+id/tv_directions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="지도보기"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/primary"
                        android:foreground="?attr/selectableItemBackground" />
                </LinearLayout>

                <!-- Phone -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_phone"
                        android:contentDescription="전화"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_phone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="031-123-4567"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/color_text_sub" />
                </LinearLayout>
            </LinearLayout>

            <!-- Countdown timer card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_timer_card"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="4dp">

                <!-- Left circle -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_timer_circle">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="마감"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tv_timer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="42:00"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Right info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="픽업 가능 시간"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/primary_dark" />

                    <TextView
                        android:id="@+id/tv_pickup_range"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="17:00 - 18:30"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="가게에서 직접 픽업해 가세요"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/primary_dark" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="16dp"
                android:background="@color/color_surface" />

            <!-- Menu section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="@dimen/spacing_lg">

                <!-- Section header with count -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tv_menu_section_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="오늘의 득템 메뉴 (0)"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_text" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_menus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="@dimen/spacing_lg"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/btn_wishlist_bottom"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_heart"
            android:background="@drawable/bg_store_card"
            android:contentDescription="찜" />

        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp">

            <ImageButton
                android:id="@+id/btn_cart"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_cart"
                android:background="@drawable/bg_store_card"
                android:contentDescription="장바구니" />

            <TextView
                android:id="@+id/tv_cart_badge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:layout_margin="2dp"
                android:background="@drawable/bg_cart_badge"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Green CTA: 시루로 바로 예약하기 -->
        <Button
            android:id="@+id/btn_reserve"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/btn_reserve_siru"
            android:textSize="@dimen/text_button"
            android:fontFamily="sans-serif-medium"
            android:textColor="?attr/colorOnSecondary"
            android:background="@drawable/bg_siru_button"
            android:backgroundTint="@null"
            android:stateListAnimator="@null" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
