<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:paddingHorizontal="@dimen/spacing_lg">

    <LinearLayout
        android:id="@+id/ll_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="56dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_gravity="end"
            android:contentDescription="시흥시 캐릭터"
            android:scaleType="fitCenter"
            android:src="@drawable/img_siheung_character" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="득템시루"
            android:textColor="@color/primary"
            android:textSize="@dimen/text_display" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:fontFamily="sans-serif-medium"
            android:text="로그인하고"
            android:textColor="@color/color_text"
            android:textSize="@dimen/text_headline" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="오늘의 남은 맛을 구해요"
            android:textColor="@color/color_text"
            android:textSize="@dimen/text_headline" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="카카오로 간편하게 시작해보세요."
            android:textColor="@color/color_text_sub"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_kakao_login"
        android:layout_width="0dp"
        android:layout_height="@dimen/cta_button_height"
        android:layout_marginBottom="16dp"
        android:background="#FEE500"
        android:fontFamily="sans-serif-medium"
        android:stateListAnimator="@null"
        android:text="카카오로 시작하기"
        android:textColor="#191919"
        android:textSize="@dimen/text_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
